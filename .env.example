# ============================================
# LeadGenius Design Suite - 環境変数設定
# ============================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# ─── 必須 ───
GEMINI_API_KEY=your-gemini-api-key          # https://aistudio.google.com

# ─── デザイン調査（推奨） ───
SERPER_API_KEY=your-serper-api-key          # https://serper.dev （無料2,500クエリ）
FIRECRAWL_API_KEY=fc-your-firecrawl-key     # https://firecrawl.dev （無料枠あり）

# ─── リード送信（LeadGenius AI用） ───
RESEND_API_KEY=your-resend-api-key          # https://resend.com
SENDER_EMAIL=sales@fulfill-corp.jp

# ─── 通知（オプション） ───
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ─── Supabase（ベクトル検索 + 永続化） ───
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
